# API
PORT=3333

# Auth
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=1d

# Recuperação de senha
FRONTEND_URL=http://localhost:5173
RESET_TOKEN_TTL_MINUTES=30

# Postgres (docker-compose)
POSTGRES_USER=momentos
POSTGRES_PASSWORD=momentos
POSTGRES_DB=momentos
POSTGRES_PORT=5432

# Backend usa esta URL (TypeORM)
DATABASE_URL=postgresql://momentos:momentos@localhost:5432/momentos?schema=public
# true em produção (Neon/Supabase exigem TLS)
DATABASE_SSL=false

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=

# Envio de email (Gmail SMTP — deixe vazio p/ usar ConsoleMailProvider em dev)
# App Password gerada em myaccount.google.com/apppasswords (precisa 2FA ativo)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# AWS S3 (fotos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
S3_BUCKET_NAME=momentos-bucket
