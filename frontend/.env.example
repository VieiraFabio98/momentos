# URL da API backend
VITE_API_URL=http://localhost:3333

# Access Key da API oficial do Unsplash (https://unsplash.com/developers)
# Sem key, a tela de login usa fotos de fallback fixas
VITE_UNSPLASH_ACCESS_KEY=

# Client ID do Google OAuth (mesmo do backend)
# Sem ele, o botão "Entrar com Google" não aparece
VITE_GOOGLE_CLIENT_ID=
